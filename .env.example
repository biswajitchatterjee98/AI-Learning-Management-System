# Copy to .env in the AI-LMS folder

DATABASE_URL=postgresql+psycopg2://ai_lms:ai_lms_password@localhost:5432/ai_lms_db
JWT_SECRET=change_me_dev_only
JWT_ALGORITHM=HS256

# Optional: how long tokens last (seconds)
JWT_TTL_SECONDS=3600

# AI settings
AI_PROVIDER=groq
AI_MODEL=llama-3.1-8b-instant
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1

# Async job processing (Phase 2)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
JOB_POLL_INTERVAL_MS=2000
CORS_ORIGINS=http://localhost:3000

